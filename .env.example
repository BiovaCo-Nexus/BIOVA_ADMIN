# ============================================================
# BiovaCo Nexus — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values.
#
# Usage:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# ============================================================

# ─── Supabase ───────────────────────────────────────────────
# Your Supabase Project ID (found in Project Settings → General)
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id

# Your Supabase Publishable / Anon Key (safe to expose client-side)
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Your Supabase Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# ─── Email (Brevo / Sendinblue) ─────────────────────────────
# API key from Brevo dashboard → SMTP & API → API Keys
VITE_BREVO_API_KEY=your_brevo_api_key

# ─── AI / LLM (OpenRouter) ──────────────────────────────────
# API key from https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=your_openrouter_api_key
