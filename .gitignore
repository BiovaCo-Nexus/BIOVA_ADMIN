# ============================================================
# BiovaCo Nexus — .gitignore
# ============================================================

# ─── Dependencies ───────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build Outputs ──────────────────────────────────────────
dist/
dist-ssr/
build/
dev-dist/
*.local

# ─── Environment & Secrets ──────────────────────────────────
# NEVER commit real secrets — use .env.example as template
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# ─── Supabase Local Dev ─────────────────────────────────────
supabase/.temp/
supabase/.branches/

# ─── Logs ───────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── OS Junk ────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Editor Configs ─────────────────────────────────────────
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ─── VSCode (keep shared team config, ignore personal) ──────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# ─── TypeScript ─────────────────────────────────────────────
*.tsbuildinfo

# ─── Testing ────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/

# ─── Misc ───────────────────────────────────────────────────
*.pem
.cache/
.parcel-cache/
.turbo/
